{
  "manifest_version": 3,
  "name": "Claude Code Counter",
  "version": "1.0.0",
  "description": "Real-time token usage monitor for Claude Code sessions.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Claude Code Counter"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
